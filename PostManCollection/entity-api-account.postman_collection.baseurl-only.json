              "raw": "{\n  \"docType\": \"CHANGE_ME_TO_ALLOWED_ENUM\",\n  \"accountNumber\": 123,\n  \"status\": \"ACTIVE\",\n  \"dob\": \"2000-01-01\",\n  \"name\": {\n    \"legalName\": \"Joe Mohan\",\n    \"dbaName\": \"JM LLC\"\n  },\n  \"address\": {\n    \"line1\": \"123 Main St\",\n    \"city\": \"Weston\",\n    \"state\": \"FL\",\n    \"countryCode\": \"US\"\n  }\n}\n",
